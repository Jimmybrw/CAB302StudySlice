<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cab302studyslice.Controller.ViewController"
            prefWidth="900" prefHeight="600">

    <!-- ========== SIDEBAR ========== -->
    <left>
        <VBox spacing="20" prefWidth="180" styleClass="sidebar">
            <Label text="STUDY SLICE" styleClass="sidebar-title"/>

            <Button text="Dashboard" styleClass="sidebar-button"/>
            <Button text="Timer" fx:id="timerButton" onAction="#goToTimer" styleClass="sidebar-button"/>
            <Button text="Explore" fx:id="exploreButton" styleClass="sidebar-button"/>
            <Button text="Settings" styleClass="sidebar-button"/>
            <Button text="Log Out" styleClass="sidebar-button"/>

            <VBox.margin>
                <Insets top="20"/>
            </VBox.margin>
        </VBox>
    </left>

    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 20;">

            <!-- WELCOME -->
            <Label text="Welcome, User" styleClass="header"/>

            <!-- MAIN BUTTONS -->
            <HBox spacing="20" alignment="CENTER">
                <Button text="timer"
                        fx:id="timerButtonMain"
                        onAction="#goToTimer"
                        styleClass="main-button"/>

                <Button text="explore sessions"
                        fx:id="exploreButtonMain"
                        onAction="#goToHistory"
                        styleClass="main-button"/>
            </HBox>

            <!-- RECENT SESSIONS -->
            <VBox spacing="10" alignment="TOP_CENTER" prefWidth="600">
                <Label text="Recent Sessions" styleClass="section-title"/>

                <HBox fx:id="recentSessionsContainer"
                      spacing="15"
                      alignment="CENTER"
                      prefHeight="120"
                      styleClass="session-box-container"/>
            </VBox>

            <!-- STATS RECAP -->
            <VBox spacing="10" alignment="TOP_CENTER" prefWidth="600">
                <Label text="Stats Recap" styleClass="section-title"/>

                <HBox spacing="30" alignment="CENTER">
                    <PieChart fx:id="pieChart"
                              prefWidth="220"
                              prefHeight="220"/>

                    <BarChart fx:id="barChart"
                              prefWidth="300"
                              prefHeight="220">
                        <xAxis>
                            <CategoryAxis label="Week"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Hours"/>
                        </yAxis>
                    </BarChart>
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>