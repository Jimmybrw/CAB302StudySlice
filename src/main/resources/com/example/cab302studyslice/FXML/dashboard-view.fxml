<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="500.0" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.cab302studyslice.Controller.StudyController">

    <Label text="Study Tracker" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    <Label fx:id="timerLabel" text="Total Study Time: 00:00:00" style="-fx-font-size: 18px;" />

    <TextArea fx:id="statusTextArea" editable="false" VBox.vgrow="ALWAYS"
              promptText="Activity log will appear here once tracking starts..." />

    <Button fx:id="toggleButton" text="Start Tracking" onAction="#handleToggleTracking"
            prefWidth="250" prefHeight="50" style="-fx-font-size: 16px;" />
</VBox>