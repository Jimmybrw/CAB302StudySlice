<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cab302studyslice.Controller.DashboardController"
            styleClass="dashboard-scroll">

    <content>
        <VBox spacing="24" styleClass="dashboard-root" fx:id="dash_topBox">

            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>

            <!-- Top heading -->
            <VBox spacing="6">
                <Label text="StudySlice" styleClass="dashboard-kicker"/>
                <Label text="Dashboard" styleClass="dashboard-title"/>
                <Label text="Track your session and review your focus in real time." styleClass="dashboard-subtitle"/>
            </VBox>

            <!-- Quick stats -->
            <HBox spacing="12">
                <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                    <Label text="Today's Time" styleClass="dashboard-mini-label"/>
                    <Label fx:id="statTodayTime" text="0h 00m" styleClass="dashboard-mini-value"/>
                </VBox>
                <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                    <Label text="Sessions" styleClass="dashboard-mini-label"/>
                    <Label fx:id="statSessions" text="0" styleClass="dashboard-mini-value"/>
                </VBox>
                <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                    <Label text="Focus Streak" styleClass="dashboard-mini-label"/>
                    <Label fx:id="statStreak" text="0 days" styleClass="dashboard-mini-value"/>
                </VBox>
                <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                    <Label text="Best Session" styleClass="dashboard-mini-label"/>
                    <Label fx:id="statBestSession" text="0h 00m" styleClass="dashboard-mini-value"/>
                </VBox>
            </HBox>

            <!-- Main session card -->
            <VBox spacing="18" styleClass="dashboard-card dashboard-session-card">
                <HBox spacing="10" alignment="CENTER" styleClass="dashboard_subSections">
                    <Button text="CURRENT SESSION" styleClass="dashboard-section-chip"/>
                    <Button text="EXPLORE SESSIONS" onAction="#onExploreClicked" styleClass="dashboard-section-chip"/>
                    <Button text="TRACKING" onAction="#onTrackingClicked" styleClass="dashboard-section-chip"/>
                </HBox>
                <Label text="Session Time" styleClass="dashboard-card-label"/>

                <StackPane alignment="CENTER_LEFT" styleClass="dashboard-timer-panel">
                    <Label fx:id="timerLabel"
                           text="Total Study Time: 00:00:00"
                           wrapText="true"
                           styleClass="dashboard-timer-text"/>
                </StackPane>

                <Label text="Start tracking when you're ready. Your activity log will update below." styleClass="dashboard-helper-text"/>

                <HBox spacing="8">
                    <Button text="Start Tracking"
                            fx:id="toggleButton"
                            onAction="#handleToggleTracking"
                            styleClass="dashboard-primary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                    <Button text="Save"
                            onAction="#handleSaveSession"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                    <Button text="Delete"
                            onAction="#handleDeleteSession"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                    <Button text="Timer"
                            onAction="#onTimerClicked"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                    <Button text="Unwrap (Test)"
                            onAction="#onWrappedTestClicked"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Bottom cards row -->
            <HBox spacing="20">
                <!-- Activity log -->
                <VBox spacing="16" styleClass="dashboard-card dashboard-log-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="ACTIVITY LOG" styleClass="dashboard-section-chip"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Waiting for session" styleClass="dashboard-waiting-pill"/>
                    </HBox>

                    <TextArea fx:id="statusTextArea"
                              editable="false"
                              wrapText="true"
                              promptText="Activity log will appear here once tracking starts..."
                              VBox.vgrow="ALWAYS"
                              styleClass="dashboard-log-area"/>
                </VBox>

                <!-- Session snapshot -->
                <VBox spacing="16" styleClass="dashboard-card dashboard-snapshot-card">
                    <Label text="SESSION SNAPSHOT" styleClass="dashboard-section-chip dashboard-chip-warm"/>

                    <VBox spacing="12" styleClass="dashboard-snapshot-item">
                        <Label text="Most Used App" styleClass="dashboard-mini-label"/>
                        <Label text="-" styleClass="dashboard-snapshot-value"/>
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-snapshot-item">
                        <Label text="Top Website" styleClass="dashboard-mini-label"/>
                        <Label text="-" styleClass="dashboard-snapshot-value"/>
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-snapshot-item">
                        <Label text="Productivity" styleClass="dashboard-mini-label"/>
                        <Label text="-" styleClass="dashboard-snapshot-value"/>
                    </VBox>
                </VBox>
            </HBox>

        </VBox>
    </content>
</ScrollPane>

