<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>


<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="500.0" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.cab302studyslice.Controller.DashboardController">

    <!-- HEADER -->
    <Label text="STUDY SLICE" styleClass="header"/>

    <!-- MAIN BUTTONS -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="start tracking"
                fx:id="toggleButton"
                onAction="#handleToggleTracking"
                styleClass="main-button"/>

        <Button text="explore sessions"
                fx:id="exploreButton"
                onAction="#onExploreClicked"
                styleClass="main-button"/>

        <!-- Temporary placing of the Wrapped button -->
        <Button text="Unwrap?"
                fx:id="wrappedButton"
                onAction="#onWrappedClicked"
                styleClass="main-button"/>
    </HBox>

    <!-- TRACKING DISPLAY -->
    <VBox spacing="5" alignment="CENTER" prefWidth="500">
        <Label fx:id="timerLabel"
               text="Total Study Time: 00:00:00"
               style="-fx-font-size: 18px;" />

        <TextArea fx:id="statusTextArea"
                  editable="false"
                  VBox.vgrow="ALWAYS"
                  promptText="Activity log will appear here once tracking starts..."
                  prefHeight="300" prefWidth="400"/>
    </VBox>

</VBox>
