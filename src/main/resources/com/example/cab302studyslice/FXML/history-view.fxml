<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane prefHeight="450.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cab302studyslice.Controller.HistoryController">
    <!-- Top: Back button top left corner -->
    <top>
        <HBox alignment="CENTER_LEFT" >
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <Button text="Back" onAction="#onBackClick" />
        </HBox>
    </top>
    <!-- CENTER: Content -->
    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <Label text="HISTORY PAGE" style="-fx-font-size: 24px;" />
            <Label text="This is where your SQLite data will be displayed." />
            <ListView fx:id="historyList" styleClass="history-list" />
        </VBox>
    </center>
</BorderPane>

