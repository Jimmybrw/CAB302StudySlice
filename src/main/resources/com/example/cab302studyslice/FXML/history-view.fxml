<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cab302studyslice.Controller.HistoryController"
            styleClass="dashboard-scroll">
    <content>
        <VBox spacing="24" styleClass="dashboard-root history-root">
            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="6">
                    <Label text="StudySlice" styleClass="dashboard-kicker"/>
                    <Label text="History" styleClass="dashboard-title"/>
                    <Label fx:id="stateMessageLabel"
                           text="Showing your latest saved sessions from SQL."
                           styleClass="dashboard-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Back to Dashboard"
                        onAction="#onBackClick"
                        styleClass="dashboard-secondary-button"/>
            </HBox>
            <VBox spacing="16" styleClass="dashboard-card">
                <Label text="OVERVIEW" styleClass="dashboard-section-chip dashboard-chip-grey"/>
                <HBox spacing="12">
                    <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Study Time" styleClass="dashboard-mini-label"/>
                        <Label fx:id="totalHoursLabel" text="00:00:00" styleClass="dashboard-mini-value"/>
                    </VBox>
                    <VBox spacing="6" styleClass="dashboard-mini-card" HBox.hgrow="ALWAYS">
                        <Label text="Saved Sessions" styleClass="dashboard-mini-label"/>
                        <Label fx:id="totalSessionsLabel" text="0" styleClass="dashboard-mini-value"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox spacing="16" styleClass="dashboard-card history-list-card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="SESSION HISTORY" styleClass="dashboard-section-chip"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="MySQL" styleClass="dashboard-waiting-pill"/>
                </HBox>
                <TilePane fx:id="historyContainer"
                          prefColumns="2"
                          hgap="16"
                          vgap="16"
                          alignment="TOP_LEFT"
                          VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="4" right="4" bottom="4" left="4"/>
                    </padding>
                </TilePane>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
