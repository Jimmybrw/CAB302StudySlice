<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cab302studyslice.Controller.TimerController"
            styleClass="dashboard-scroll">
    <content>
        <VBox spacing="24" styleClass="dashboard-root">
            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="6">
                    <Label text="StudySlice" styleClass="dashboard-kicker"/>
                    <Label text="Tracking" styleClass="dashboard-title"/>
                    <Label text="Spin the dial to set your session timer." styleClass="dashboard-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Back to Dashboard"
                        onAction="#goToDashboard"
                        styleClass="dashboard-secondary-button"/>
            </HBox>

            <!-- Clock timer card -->
            <VBox spacing="16" styleClass="dashboard-card" alignment="CENTER">

                <!-- Edit button pinned to the top-right of the card -->
                <HBox maxWidth="Infinity">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="editButton"
                            text="✏  Edit Time"
                            onAction="#handleEditButton"
                            style="-fx-font-size: 12px; -fx-padding: 7 18;
                                   -fx-background-color: #819D93; -fx-text-fill: white;
                                   -fx-background-radius: 999; -fx-cursor: hand;"/>
                </HBox>

                <!-- Dial -->
                <StackPane alignment="CENTER" maxWidth="340" maxHeight="340">
                    <Canvas fx:id="timerCanvas" width="320" height="320"/>
                    <Label fx:id="countdownLabel" text="00:00"
                           mouseTransparent="true"
                           style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #2e2e2e;"/>
                </StackPane>

                <Label fx:id="timerStatusLabel"
                       text="Click ✏ Edit Time to set your timer."
                       styleClass="dashboard-helper-text"/>

                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="startTimerButton"
                            text="Start"
                            onAction="#handleStartTimer"
                            styleClass="dashboard-primary-button"
                            style="-fx-font-size: 14px; -fx-padding: 12 36;"/>
                    <Button fx:id="stopTimerButton"
                            text="Stop"
                            onAction="#handleStopTimer"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 14px; -fx-padding: 12 36;"
                            disable="true"/>
                </HBox>
            </VBox>

            <!-- Session time + save/delete -->
            <VBox spacing="16" styleClass="dashboard-card dashboard-session-card">
                <Label text="Session Time" styleClass="dashboard-card-label"/>
                <StackPane alignment="CENTER_LEFT" styleClass="dashboard-timer-panel">
                    <Label fx:id="timerLabel"
                           text="Total Study Time: 00:00:00"
                           wrapText="true"
                           styleClass="dashboard-timer-text"/>
                </StackPane>
                <HBox spacing="8">
                    <Button fx:id="saveButton"
                            text="Save Session"
                            onAction="#handleSaveSession"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            disable="true"/>
                    <Button fx:id="deleteButton"
                            text="Delete"
                            onAction="#handleDeleteSession"
                            styleClass="dashboard-secondary-button"
                            style="-fx-font-size: 13px; -fx-padding: 10 10;"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            disable="true"/>
                </HBox>
            </VBox>

            <!-- Activity log -->
            <VBox spacing="16" styleClass="dashboard-card dashboard-log-card">
                <HBox alignment="CENTER_LEFT">
                    <Label text="ACTIVITY LOG" styleClass="dashboard-chip-grey"
                           style="-fx-background-radius: 999; -fx-padding: 6 14; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Waiting for session" styleClass="dashboard-waiting-pill"/>
                </HBox>
                <TextArea fx:id="statusTextArea"
                          editable="false"
                          wrapText="true"
                          promptText="Activity log will appear here once the timer starts..."
                          VBox.vgrow="ALWAYS"
                          styleClass="dashboard-log-area"/>
            </VBox>

            <!-- Hidden toggle button for engine compatibility -->
            <Button fx:id="toggleButton" visible="false" managed="false"/>

        </VBox>
    </content>
</ScrollPane>
