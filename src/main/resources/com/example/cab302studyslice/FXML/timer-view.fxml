<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cab302studyslice.Controller.TimerController"
            prefWidth="900" prefHeight="600">

    <!-- Menu Sidebar / will probably work on making this pop out rahter than constant -->
    <left>
        <VBox spacing="20" prefWidth="180" styleClass="sidebar">
            <Label text="STUDY SLICE" styleClass="sidebar-title"/>

            <Button text="Dashboard" fx:id="dashboardButton" onAction="#goToDashboard" styleClass="sidebar-button"/>
            <Button text="Timer" styleClass="sidebar-button-selected"/>
            <Button text="Explore" fx:id="exploreButtonSB" onAction="#onExploreClicked" styleClass="sidebar-button"/>
            <Button text="Settings" styleClass="sidebar-button"/>
            <Button text="Log Out" styleClass="sidebar-button"/>

            <VBox.margin>
                <Insets top="20"/>
            </VBox.margin>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" alignment="TOP_CENTER">
            <Label text="Start tracking when you're ready. Your activity log will update below." styleClass="dashboard-helper-text"/>

            <HBox spacing="8">
                <Button text="Start Tracking"
                        fx:id="toggleButton"
                        onAction="#handleToggleTracking"
                        styleClass="dashboard-primary-button"
                        style="-fx-font-size: 13px; -fx-padding: 10 10;"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
                <Button text="Save"
                        onAction="#handleSaveSession"
                        styleClass="dashboard-secondary-button"
                        style="-fx-font-size: 13px; -fx-padding: 10 10;"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
                <Button text="Delete"
                        onAction="#handleDeleteSession"
                        styleClass="dashboard-secondary-button"
                        style="-fx-font-size: 13px; -fx-padding: 10 10;"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>

                <Button text="View History"
                        fx:id="exploreButton"
                        onAction="#onExploreClicked"
                        styleClass="dashboard-secondary-button"
                        style="-fx-font-size: 13px; -fx-padding: 10 10;"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
                <Button text="Mini Timer"
                        onAction="#onTimerClicked"
                        styleClass="dashboard-secondary-button"
                        style="-fx-font-size: 13px; -fx-padding: 10 10;"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Bottom cards row -->
            <HBox spacing="20">
            <!-- Activity log -->
                <VBox spacing="16" styleClass="dashboard-card dashboard-log-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="ACTIVITY LOG" styleClass="dashboard-section-chip"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Waiting for session" styleClass="dashboard-waiting-pill"/>
                </HBox>

                <TextArea fx:id="statusTextArea"
                          editable="false"
                          wrapText="true"
                          promptText="Activity log will appear here once tracking starts..."
                          VBox.vgrow="ALWAYS"
                          styleClass="dashboard-log-area"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>