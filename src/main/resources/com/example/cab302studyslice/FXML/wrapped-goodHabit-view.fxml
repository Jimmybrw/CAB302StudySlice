<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootStack"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.cab302studyslice.Controller.WrappedGoodHabitController">

    <!-- Base Background -->
    <Region fx:id="backgroundLayer"
            styleClass="wrapped-goodHabit-root"
            maxWidth="Infinity"
            maxHeight="Infinity"/>

    <!-- Content -->
    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="24" right="24" bottom="10" left="24"/>
                </padding>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#onBackClick"
                        styleClass="wrapped-back-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="pageIndicatorLabel"
                       text="06 / 00"
                       styleClass="wrapped-page-indicator"/>
            </HBox>
        </top>

        <center>
            <StackPane>
                <VBox alignment="CENTER" spacing="28">
                    <padding>
                        <Insets top="20" right="40" bottom="40" left="40"/>
                    </padding>

                    <Label text="What worked for you?"
                           styleClass="wrapped-page-label"/>

                    <Label fx:id="goodHabitLabel"
                           text="Staying in one task"
                           wrapText="true"
                           styleClass="wrapped-page-hero"/>

                    <Label fx:id="goodHabitSupportLabel"
                           text="Your strongest habit was staying focused in one work stream for a longer stretch."
                           wrapText="true"
                           maxWidth="620"
                           alignment="CENTER"
                           textAlignment="CENTER"
                           styleClass="wrapped-page-subtext"/>

                    <HBox alignment="CENTER_RIGHT" maxWidth="Infinity">
                        <Button fx:id="nextButton"
                                text="Next"
                                onAction="#onNextClick"
                                styleClass="wrapped-soft-next-button"/>
                    </HBox>
                </VBox>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>

