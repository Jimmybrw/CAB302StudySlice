<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.Button?>
        <?import javafx.scene.control.Label?>
        <?import javafx.scene.layout.VBox?>
        <?import javafx.scene.layout.HBox?>
        <?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302studyslice.LaunchController"
           style="-fx-background-color: linear-gradient(to bottom, #F59A2A, #657972);">

<VBox spacing="25" alignment="CENTER">
    <Label text="Welcome to Study Slice"
           style="-fx-font-size: 36px; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label text="Track your study sessions. Understand your habits. Improve your focus."
           wrapText="true"
           style="-fx-font-size: 16px; -fx-text-fill: #E3F2FD;"
           maxWidth="400"/>

    <HBox spacing="20" alignment="CENTER">
        <Button text="Sign In"
                onAction="#handleSignIn"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #145DA0;
                           -fx-font-size: 16px; -fx-padding: 10 25; -fx-background-radius: 8;"/>

        <Button text="Sign Up"
                onAction="#handleSignUp"
                style="-fx-background-color: #1E487A; -fx-text-fill: white;
                           -fx-font-size: 16px; -fx-padding: 10 25; -fx-background-radius: 8;"/>
    </HBox>
</VBox>

</StackPane>